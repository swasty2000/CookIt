<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:rippleColor="#20FFFFFF"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Левый цветной акцент -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="4dp"
            android:layout_height="60dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_accent_bar"
            android:backgroundTint="@color/green_primary" />

        <!-- Эмодзи блюда -->
        <TextView
            android:id="@+id/tvDishEmoji"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:gravity="center"
            android:text="🍳"
            android:textSize="32sp" />

        <!-- Информация о блюде -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDishName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Название блюда"
                android:textColor="@color/text_light"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDishDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="2"
                android:ellipsize="end"
                android:text="Краткое описание блюда"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <!-- Бейдж времени готовки -->
            <TextView
                android:id="@+id/tvCookTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_time_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="⏱ 30 мин"
                android:textColor="@color/green_accent"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Стрелка вправо -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="@color/red_accent"
            android:textSize="28sp"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>