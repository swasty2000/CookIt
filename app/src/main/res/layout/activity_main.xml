<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Градиентное свечение сверху -->

    <!-- Большой эмодзи еды -->

    <View
        android:id="@+id/topGlow"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="52dp"
        android:alpha="0.35"
        android:background="@drawable/bg_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.56"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="🍳"
        android:textSize="100sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Название приложения -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:letterSpacing="0.08"
        android:text="CookIt"
        android:textColor="@color/green_primary"
        android:textSize="52sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvEmoji" />

    <!-- Зелёная черта под названием -->
    <View
        android:id="@+id/dividerLine"
        android:layout_width="60dp"
        android:layout_height="3dp"
        android:layout_marginTop="4dp"
        android:background="@color/red_accent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName" />

    <!-- Подзаголовок -->

    <!-- Декоративная строка с эмодзи -->

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="104dp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:text="Скажи, что есть в холодильнике — и мы предложим вкусные блюда"
        android:textAlignment="center"
        android:textColor="@color/text_muted"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topGlow" />

    <LinearLayout
        android:id="@+id/llFeatures"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/btnStart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_feature_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="🥗 Быстро"
            android:textColor="@color/green_accent"
            android:textSize="14sp" />

        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_feature_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="🍽️ Вкусно"
            android:textColor="@color/green_accent"
            android:textSize="14sp" />

        <View
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_feature_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:text="🤖 ИИ"
            android:textColor="@color/green_accent"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Кнопка Начать -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="48dp"
        android:letterSpacing="0.06"
        android:text="Начать готовить  →"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:backgroundTint="@color/red_accent"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>